---
import NavigationLink from "./NavigationLink.astro";

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.split("/");
---

<NavigationLink title="Home" url="" currentpath={currentPath[1]} />
<NavigationLink title="About" url="About" currentpath={currentPath[1]} />
<NavigationLink title="Projects" url="Projects" currentpath={currentPath[1]} />
<NavigationLink title="Extras" url="Extras" currentpath={currentPath[1]} />
---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
---

<Layout title="Maxim - PC Service" navMode="service">

<!-- Service Banner -->
<a href="/" class="fixed -top-[65px] left-0 right-0 z-40 px-4 sm:px-10 md:px-32 pt-2 pointer-events-auto">
  <div class="border dark:border-yellow-700 border-yellow-400 bg-yellow-50 dark:bg-yellow-900 backdrop-blur-sm rounded-xl p-3 text-sm hover:bg-yellow-100 dark:hover:bg-yellow-900 transition-colors duration-200">
    <p class="font-mono text-yellow-600 dark:text-yellow-500 text-xs">
      ⚠️ Dieser Service wird aktuell nicht mehr angeboten. Kehre hier zurück →
    </p>
    <p class="font-mono text-yellow-600 dark:text-yellow-500 text-xs">
      ⚠️ This service is currently no longer offered. Return here →
    </p>
  </div>
</a>

  <div
    class="flex flex-col xl:flex-row justify-between px-4 sm:px-10 md:px-32 items-center -mt-4 md:-mt-0 2xl:mt-10 xl:mb-40 2xl:mb-60"
  >
    <div class="w-full xl:w-2/3 flex flex-row -mb-10 xl:mb-0 xl:flex-col justify-between items-center xl:items-start">

      <div
        class="w-1/2 xl:w-full text-xl ssm:text-3xl sm:text-4xl md:text-4xl lg:text-5xl xl:text-6xl text-center xl:text-start transition-transform duration-300 transform hover:scale-105 mt-16 xl:-mb-0"
      >
        Hey, ich bin<br />
        <span id="dynamic-header-text" class="dark:text-blue-500 text-blue-500"
          >Informatiker</span
        ><br />
      </div>

      <div
        class="w-1/2 -mb-10 xl:w-full xl:mb-0 xl:hidden flex justify-center items-center transition-transform duration-300 transform hover:scale-105">
        <div id="logoSwitch">
          <img src="/images/HellLogo.png" class="" />
        </div>
      </div>

      <p
        class="hidden xl:block py-20 transition-transform duration-300 transform hover:scale-105 text-lg sm:text-xl md:text-2xl -mb-10" style="line-height: 2;">
        Ich bin derzeit Masterstudent in Berlin und studiere Computer Engineering an der TU Berlin.
        Nach meinem Bachelorabschluss habe ich mein Studium vertieft und beschäftige mich weiterhin
        mit Themen rund um Computer, Hardware und Software. Neben dem Studium unterstütze ich
        Privatpersonen und kleine Unternehmen dabei, ihre PC- und Laptop-Probleme zu lösen – aus
        eigener Erfahrung weiß ich, wie frustrierend technische Schwierigkeiten sein können.
      </p>

      <div class="hidden xl:flex items-center mt-8 mb-0 md:mb-12 lg:mb-20 xl:mb-0">
        <Button url="/pc-service/Angebote-service" title="Angebote" external={true} />
        <a
          href="/pc-service/Kontakt-service"
          class="ml-10 font-medium dark:text-dark text-light underline transition-transform duration-300 transform hover:scale-105"
          >Kontakt</a
        >
      </div>
    </div>

    <p
      class="block xl:hidden py-20 transition-transform duration-300 transform hover:scale-105 text-lg sm:text-xl md:text-2xl -mb-10" style="line-height: 2;">
        Ich bin derzeit Masterstudent in Berlin und studiere Computer Engineering an der TU Berlin.
        Nach meinem Bachelorabschluss habe ich mein Studium vertieft und beschäftige mich weiterhin
        mit Themen rund um Computer, Hardware und Software. Neben dem Studium unterstütze ich
        Privatpersonen und kleine Unternehmen dabei, ihre PC- und Laptop-Probleme zu lösen – aus
        eigener Erfahrung weiß ich, wie frustrierend technische Schwierigkeiten sein können.
    </p>

    <div class="flex xl:hidden items-center mt-8 mb-0 md:mb-12 lg:mb-20 xl:mb-0">
      <Button url="/pc-service/Angebote-service" title="Angebote" external={true} />
      <a
        href="/pc-service/Kontakt-service"
        class="ml-10 font-medium dark:text-dark text-light underline transition-transform duration-300 transform hover:scale-105"
        >Kontakt</a
      >
    </div>

    <div
      id="logoSwitch1"
      class="hidden xl:flex w-1/4 xl:w-1/3 justify-center items-center transition-transform duration-300 transform hover:scale-110 ml-32"
    >
      <img src="/images/HellLogo.png" class="w-full h-auto" />
    </div>
  </div>



  <center>
    <button id="auto-scroll-btn" class="hidden 2xl:block -translate-y-52 2xl:-translate-y-40 hover:cursor-pointer dark:bg-dark bg-light rounded-full p-1 transition-transform duration-300 transform hover:scale-110">
      <div id="icon7">
        <img src="/icons/arrow-small.svg" class="w-10 h-10" />
      </div>
    </button>
  </center>
  
  <script src="../../js/smoothScroll.js"></script>
  <script src="../../js/themeHandler.js"></script>
  <script src="../../js/pageHandler.js"></script>
</Layout>
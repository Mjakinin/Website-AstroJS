---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Maxim" navMode="portfolio">
  <div class="flex flex-col xl:flex-row justify-between px-4 sm:px-10 md:px-32 items-center -mt-20 md:-mt-0 2xl:mt-10 xl:mb-40 2xl:mb-60">

    <div class="w-full xl:w-2/3 flex flex-row -mb-10 xl:mb-0 xl:flex-col justify-between items-center xl:items-start">

      <div class="w-1/2 xl:w-full text-xl ssm:text-3xl sm:text-4xl md:text-4xl lg:text-5xl xl:text-6xl text-center xl:text-start transition-transform duration-300 transform hover:scale-105 mt-16 xl:-mb-0">
        Hey, I'm<br />
        <span id="dynamic-header-text" class="dark:text-blue-500 text-blue-500">
          Computer Engineer
        </span><br />
      </div>

      <!-- Mobile Bild -->
      <div class="w-1/2 -mb-10 xl:w-full xl:mb-0 xl:hidden flex justify-center items-center transition-transform duration-300 transform hover:scale-105">
        <div id="profilePicMobile">
          <img src="/images/profile.jpg" class="rounded-full w-40 h-40 object-cover" />
        </div>
      </div>

      <p class="hidden xl:block py-20 transition-transform duration-300 transform hover:scale-105 text-lg sm:text-xl md:text-2xl -mb-10" style="line-height: 2;">
        I'm a Master's student in Computer Engineering at TU Berlin.
        My interests lie in Robotics, Computer Vision, autonomous systems,
        and Industry 4.0. Here I share projects and insights
        from my studies and technical work.
      </p>

      <!-- Desktop Buttons -->
      <div class="hidden xl:flex items-center gap-4 mt-8 mb-0 md:mb-12 lg:mb-20 xl:mb-0">
        <a href="/Projects"
          class="px-5 py-2 rounded-lg font-medium bg-blue-600 hover:bg-blue-500 text-white transition-all duration-300 transform hover:scale-105 hover:shadow-lg hover:shadow-blue-500/30">
          Projects →
        </a>
        <a href="/pc-service"
          class="px-5 py-2 rounded-lg font-medium border border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200 dark:border-gray-600 dark:text-gray-500 dark:hover:border-gray-400 dark:hover:text-gray-300 transition-all duration-300 transform hover:scale-105 text-base">
          Former PC Service ↗
        </a>
      </div>
    </div>

    <!-- Mobile Text -->
    <p class="block xl:hidden py-20 transition-transform duration-300 transform hover:scale-105 text-lg sm:text-xl md:text-2xl -mb-10" style="line-height: 2;">
      I'm a Master's student in Computer Engineering at TU Berlin.
      My interests lie in Robotics, Computer Vision, autonomous systems,
      and Industry 4.0. Here I share projects and insights
      from my studies and technical work.
    </p>

    <!-- Mobile Buttons -->
    <div class="flex xl:hidden items-center gap-4 mt-8 mb-0 md:mb-12 lg:mb-20 xl:mb-0">
      <a href="/Projects"
        class="px-5 py-2 rounded-lg font-medium bg-blue-600 hover:bg-blue-500 text-white transition-all duration-300 transform hover:scale-105 hover:shadow-lg hover:shadow-blue-500/30">
        Projects →
      </a>
      <a href="/pc-service"
        class="px-5 py-2 rounded-lg font-medium border border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200 dark:border-gray-600 dark:text-gray-500 dark:hover:border-gray-400 dark:hover:text-gray-300 transition-all duration-300 transform hover:scale-105 text-base">
        Former PC Service ↗
      </a>
    </div>

<!-- Desktop Bild -->
<div id="profilePicDesktop" class="hidden xl:flex w-1/4 xl:w-1/3 justify-center items-start transition-transform duration-300 transform hover:scale-110 ml-32 mt-8">
  <img src="/images/profile.jpg" class="rounded-full w-80 h-80 object-cover shadow-2xl" />
</div>

  <script src="../js/themeHandler.js"></script>
  <script src="../js/pageHandler.js"></script>
</Layout>